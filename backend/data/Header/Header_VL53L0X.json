            "return_type": "float"
        },
        {
            "name": "setMeasurementTimingBudget",
            "description": "Sets measurement timing budget",
            "parameters": [
                "uint32_t budget_us"
            ],
            "return_type": "bool"
        },
        {
            "name": "getMeasurementTimingBudget",
            "description": "Gets measurement timing budget",
            "parameters": [],
            "return_type": "uint32_t"
        },
        {
            "name": "setVcselPulsePeriod",
            "description": "Sets VCSEL pulse period",
            "parameters": [
                "vcselPeriodType type",

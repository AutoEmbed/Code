                "uint8_t const * src",
                "uint8_t count"
            ],
            "return_type": "void"
        },
        {
            "name": "readMulti",
            "description": "Reads multiple bytes from register",
            "parameters": [
                "uint8_t reg",
                "uint8_t * dst",
                "uint8_t count"
            ],
            "return_type": "void"
        },
        {

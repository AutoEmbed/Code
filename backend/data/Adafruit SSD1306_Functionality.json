    "ssd1306_128x32_spi.ino": {
        "ssd1306_128x32_spi.ino": [
            {
                "functionality": "Demonstrates various basic and advanced drawing operations on a 128x32 OLED display using the SSD1306 driver and Adafruit library",
                "API": [
                    "begin(SSD1306_SWITCHCAPVCC)",
                    "display()",
                    "clearDisplay()",
                    "drawPixel(10, 10, SSD1306_WHITE)",
                    "display()",
                    "invertDisplay(true)",
                    "invertDisplay(false)",
                    "clearDisplay()",
                    "drawLine(0, 0, i, display.height()-1, SSD1306_WHITE)",
                    "drawLine(0, 0, display.width()-1, i, SSD1306_WHITE)",
                    "drawLine(0, display.height()-1, i, 0, SSD1306_WHITE)",
                    "drawLine(0, display.height()-1, display.width()-1, i, SSD1306_WHITE)",
                    "drawLine(display.width()-1, display.height()-1, i, 0, SSD1306_WHITE)",
                    "drawLine(display.width()-1, display.height()-1, 0, i, SSD1306_WHITE)",
                    "drawLine(display.width()-1, 0, 0, i, SSD1306_WHITE)",
                    "drawLine(display.width()-1, 0, i, display.height()-1, SSD1306_WHITE)",
                    "clearDisplay()",
                    "drawRect(i, i, display.width()-2*i, display.height()-2*i, SSD1306_WHITE)",
                    "display()",
                    "clearDisplay()",
                    "fillRect(i, i, display.width()-i*2, display.height()-i*2, SSD1306_INVERSE)",
                    "display()",
                    "clearDisplay()",
                    "drawCircle(display.width()/2, display.height()/2, i, SSD1306_WHITE)",
                    "display()",
                    "clearDisplay()",
                    "fillCircle(display.width()/2, display.height()/2, i, SSD1306_INVERSE)",
                    "display()",
                    "clearDisplay()",
                    "drawRoundRect(i, i, display.width()-2*i, display.height()-2*i, display.height()/4, SSD1306_WHITE)",
                    "display()",
                    "clearDisplay()",
                    "fillRoundRect(i, i, display.width()-2*i, display.height()-2*i, display.height()/4, SSD1306_INVERSE)",
                    "display()",
                    "clearDisplay()",
                    "drawTriangle(display.width()/2, display.height()/2-i, display.width()/2-i, display.height()/2+i, display.width()/2+i, display.height()/2+i, SSD1306_WHITE)",
                    "display()",
                    "clearDisplay()",
                    "fillTriangle(display.width()/2, display.height()/2-i, display.width()/2-i, display.height()/2+i, display.width()/2+i, display.height()/2+i, SSD1306_INVERSE)",
                    "display()",
                    "clearDisplay()",
                    "setTextSize(1)",
                    "setTextColor(SSD1306_WHITE)",
                    "setCursor(0, 0)",
                    "cp437(true)",
                    "write(' ')",
                    "write(i)",
                    "display()",
                    "clearDisplay()",
                    "setTextSize(1)",
                    "setTextColor(SSD1306_WHITE)",
                    "setCursor(0,0)",
                    "println(F(\"Hello, world!\"))",
                    "setTextColor(SSD1306_BLACK, SSD1306_WHITE)",
                    "println(3.141592)",
                    "setTextSize(2)",
                    "setTextColor(SSD1306_WHITE)",
                    "print(F(\"0x\"))",
                    "println(0xDEADBEEF, HEX)",
                    "display()",
                    "clearDisplay()",
                    "setTextSize(2)",
                    "setTextColor(SSD1306_WHITE)",
                    "setCursor(10, 0)",
                    "println(F(\"scroll\"))",
                    "display()",
                    "startscrollright(0x00, 0x0F)",
                    "stopscroll()",
                    "startscrollleft(0x00, 0x0F)",
                    "stopscroll()",
                    "startscrolldiagright(0x00, 0x07)",
                    "startscrolldiagleft(0x00, 0x07)",
                    "stopscroll()",
                    "clearDisplay()",
                    "drawBitmap((display.width() - LOGO_WIDTH) / 2, (display.height() - LOGO_HEIGHT) / 2, logo_bmp, LOGO_WIDTH, LOGO_HEIGHT, 1)",
                    "drawBitmap(icons[f][XPOS], icons[f][YPOS], bitmap, w, h, SSD1306_WHITE)",
                    "display()",
                    "clearDisplay()",
                    "display()"
                ]
            }
        ]
    },

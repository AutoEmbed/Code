{
    "Adafruit_BMP085.h": [
        {
            "name": "begin",
            "description": "Starts I2C connection",
            "parameters": [
                "uint8_t mode = BMP085_ULTRAHIGHRES",
                "TwoWire *wire = &Wire"
            ],
            "return_type": "bool"
        },
        {
            "name": "readTemperature",
            "description": "Gets the temperature over I2C",
            "parameters": [],
            "return_type": "float"
        },
        {
            "name": "readPressure",
            "description": "Gets the pressure over I2C",
            "parameters": [],
            "return_type": "int32_t"
        },
        {
            "name": "readSealevelPressure",
            "description": "Calculates pressure at sea level",
            "parameters": [
                "float altitude_meters = 0"
            ],
            "return_type": "int32_t"
        },
        {
            "name": "readAltitude",
            "description": "Reads the altitude",
            "parameters": [
                "float sealevelPressure = 101325"
            ],
            "return_type": "float"
        },
        {
            "name": "readRawTemperature",
            "description": "Reads the raw temperature",
            "parameters": [],
            "return_type": "uint16_t"
        },
        {
            "name": "readRawPressure",
            "description": "Reads the raw pressure",
            "parameters": [],
            "return_type": "uint32_t"
        }
    ]
}